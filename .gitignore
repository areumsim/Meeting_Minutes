# ── 비밀 설정 (절대 git에 올리지 말 것) ─────────
config.json
.env

# ── 출력 파일 ─────────────────────────────────────
output/
*.log

# ── 빌드 산출물 ──────────────────────────────────
build/
dist/
*.tsbuildinfo

# ── Node ─────────────────────────────────────────
node_modules/

# ── iOS / Capacitor ──────────────────────────────
*.xcworkspace
xcuserdata/
DerivedData/
*.ipa
.swiftpm/
web/frontend/ios/App/App/public/
web/frontend/ios/App/Pods/

# ── 플랫폼별 바이너리 (esbuild, rollup 등) ──────
*.exe
*.node

# ── Python ────────────────────────────────────────
__pycache__/
*.pyc
*.pyo
*.pyd
.Python

# ── 데이터베이스 ─────────────────────────────────
*.db

# ── 임시 파일 ─────────────────────────────────────
*.tmp
*.bak
temp_*

# ── 오디오 백업 (크래시 복구용 대용량 파일) ─────────
