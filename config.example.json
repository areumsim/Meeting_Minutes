{
  "_readme": [
    "이 파일을 config.json 으로 복사하고 실제 값을 채우세요.",
    "config.json 은 .gitignore 에 포함되어 있어 git에 올라가지 않습니다.",
    "복사: copy config.example.json config.json  (Windows)",
    "복사: cp config.example.json config.json    (Mac/Linux)"
  ],

  "api": {
    "_comment": "API 키 — 환경변수(OPENAI_API_KEY 등)가 있으면 환경변수 우선",
    "openai_api_key":    "sk-proj-...",
    "anthropic_api_key": "sk-ant-..."
  },

  "ssl": {
    "_comment": "회사/학교 네트워크에서 SSL 오류 시 false 로 설정",
    "verify": false
  },

  "models": {
    "_comment": "아래 _options 목록에서 선택해 값을 변경하세요.",

    "_stt_options": [
      "gpt-4o-mini-transcribe",
      "gpt-4o-mini-transcribe-2025-12-15",
      "gpt-4o-transcribe",
      "gpt-4o-transcribe-diarize",
      "whisper-1"
    ],
    "stt": "gpt-4o-mini-transcribe-2025-12-15",

    "_llm_options": ["gpt", "claude"],
    "llm": "gpt",

    "_gpt_model_options": [
      "gpt-4o",
      "gpt-4o-mini",
      "o1",
      "o1-mini",
      "o3-mini"
    ],
    "_gpt_model_note": "o1/o3 계열은 reasoning 모델 — 품질은 높으나 느리고 비용 높음",
    "gpt_model": "gpt-4o-mini",

    "_minutes_model_comment": "회의록 생성 모델 — 미설정 시 gpt_model 사용 (상세 기록이므로 고성능 모델 권장)",
    "minutes_model": "gpt-4o",

    "_summary_model_comment": "요약본 생성 모델 — 미설정 시 gpt_model 사용",
    "summary_model": "gpt-4o",

    "_claude_model_options": [
      "claude-opus-4-6",
      "claude-sonnet-4-6",
      "claude-haiku-4-5-20251001"
    ],
    "claude_model": "claude-opus-4-6",

    "_translate_model_options": ["gpt-4o-mini", "gpt-4o"],
    "translate_model": "gpt-4o-mini"
  },

  "realtime": {
    "_comment": "실시간 녹취(realtime_transcription.py) 기본값",

    "_language_options": ["en", "ko", "auto"],
    "language": "en",

    "translate": false,
    "chunk_duration": 3.0,

    "_type_options": ["meeting", "seminar", "lecture"],
    "type": "meeting",

    "_audio_backup_comment": "true 시 세션 오디오를 PCM 파일로 백업 (크래시 복구용, ~115MB/hr)",
    "audio_backup": true,

    "_mode_comment": "http=기존 청크 방식, ws=WebSocket 스트리밍 (~1초 지연, 비용 ~3배), auto=자동",
    "_mode_options": ["http", "ws", "auto"],
    "mode": "http",

    "_ws_vad_comment": "WebSocket 모드 VAD 설정 — server_vad(빠름) 또는 semantic_vad(자연스러움)",
    "_ws_vad_options": ["server_vad", "semantic_vad"],
    "ws_vad_type": "server_vad",

    "_ws_vad_eagerness_comment": "semantic_vad 전용 — 발화 종료 판단 민감도",
    "_ws_vad_eagerness_options": ["low", "medium", "high", "auto"],
    "ws_vad_eagerness": "medium",

    "_ws_noise_reduction_comment": "WebSocket 노이즈 리덕션 — near_field(헤드셋), far_field(회의실)",
    "_ws_noise_reduction_options": ["near_field", "far_field", null],
    "ws_noise_reduction": "near_field"
  },

  "email": {
    "_comment": [
      "Gmail 앱 비밀번호: https://myaccount.google.com/apppasswords (2단계 인증 먼저)",
      "Naver: 메일 설정 → POP3/SMTP 사용 → 비밀번호 발급"
    ],
    "sender":    "sender@naver.com",
    "password":  "",
    "recipient": "recipient@company.com"
  },

  "notify": {
    "_comment": [
      "Slack: 채널 → 앱 → Incoming Webhooks → Webhook URL 복사",
      "Teams: 채널 → 커넥터 → Incoming Webhook → URL 복사",
      "환경변수 SLACK_WEBHOOK_URL / TEAMS_WEBHOOK_URL 도 지원"
    ],
    "slack": { "webhook_url": "" },
    "teams": { "webhook_url": "" }
  },

  "output_dir": "./output"
}
