{
	"appId": "com.meetingminutes.app",
	"appName": "AI 회의록",
	"webDir": "dist",
	"server": {
		"androidScheme": "https"
	},
	"ios": {
		"contentInset": "automatic",
		"backgroundColor": "#ffffff",
		"preferredContentMode": "mobile",
		"allowsLinkPreview": false
	},
	"plugins": {
		"SplashScreen": {
			"launchAutoHide": true,
			"androidScaleType": "CENTER_CROP"
		},
		"Keyboard": {
			"resize": "body",
			"resizeOnFullScreen": true
		},
		"StatusBar": {
			"style": "dark"
		}
	},
	"packageClassList": [
		"KeepAwakePlugin",
		"HapticsPlugin",
		"KeyboardPlugin",
		"LocalNotificationsPlugin",
		"CAPNetworkPlugin",
		"SharePlugin",
		"SplashScreenPlugin",
		"StatusBarPlugin"
	]
}
